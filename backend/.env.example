DATABASE_URL="postgresql://postgres:campaign_secure_pass_2026@localhost:5432/campaign_db?schema=public"
PORT=5001
USE_MEMORY_DB=true

# Optional Shopify checkout integration for admin registration.
# When these values are set, registration redirects to Shopify checkout and
# the admin is activated only after the paid-order webhook is received.
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_STOREFRONT_TOKEN="your-storefront-access-token"
SHOPIFY_MONTHLY_VARIANT_ID="gid://shopify/ProductVariant/0000000000"
SHOPIFY_ANNUAL_VARIANT_ID="gid://shopify/ProductVariant/0000000000"
SHOPIFY_WEBHOOK_SECRET="your-shopify-app-client-secret"

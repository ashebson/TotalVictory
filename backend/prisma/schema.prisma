datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id             Int             @id
  adminId        Int             @default(1)
  admin          Admin           @relation(fields: [adminId], references: [id], onDelete: Cascade)
  name           String
  sourceFileName String?
  sourceHeaders  Json?
  createdAt      DateTime        @default(now())
  inviteToken    String          @default("")
  contacts       Contact[]
  callLogs       CallLog[]
  callerProjects CallerProject[]

  @@index([adminId])
}

model Caller {
  id             Int             @id
  adminId        Int             @default(1)
  admin          Admin           @relation(fields: [adminId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  whatsappTemplate String?
  passcodeHash   String          @default("")
  createdAt      DateTime        @default(now())
  contacts       Contact[]
  callLogs       CallLog[]
  callerProjects CallerProject[]

  @@unique([adminId, phone])
}

model CallerProject {
  id        Int      @id @default(autoincrement())
  callerId  Int
  projectId Int
  caller    Caller   @relation(fields: [callerId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([callerId, projectId])
}

model Contact {
  id             Int             @id
  projectId    Int
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  city         String?
  sector       String?
  familySize   Int?
  notes        String?
  callNotes    String?
  sourceData   Json?
  status       String    @default("PENDING")
  lastCalledAt DateTime?
  callerId     Int?
  caller       Caller?   @relation(fields: [callerId], references: [id])
  callLogs     CallLog[]

  @@unique([projectId, phone])
  @@index([projectId, status, lastCalledAt])
  @@index([callerId])
}

model CallLog {
  id             Int             @id
  projectId Int
  callerId  Int
  contactId Int
  status    String
  timestamp DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  caller    Caller   @relation(fields: [callerId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([callerId, timestamp])
  @@index([projectId, timestamp])
}

model Setting {
  adminId   Int      @default(1)
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt @default(now())

  @@id([adminId, key])
}


model Admin {
  id             Int             @id
  fullName      String
  email         String         @unique
  phone         String         @unique
  organization  String
  passcode      String?
  passcodeHash   String?         @unique
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now())
  approvedAt    DateTime?
  subscriptions Subscription[]
  projects      Project[]
  callers       Caller[]
  settings      Setting[]
}

model Subscription {
  id             Int             @id
  adminId   Int
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  planId    String
  status    String   @default("ACTIVE")
  provider  String   @default("demo")
  amount    Int
  currency  String   @default("ILS")
  createdAt DateTime @default(now())
  expiresAt DateTime?
}
